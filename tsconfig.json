{
  "compilerOptions": {
    "target": "es2020",
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": false,
    "declaration": true,
    "declarationMap": true,
    "pretty": true,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "removeComments": false,
    "lib": [
      "es2020"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "lib"
  ]
}
